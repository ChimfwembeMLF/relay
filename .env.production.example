# Copy to Dokploy / host secrets — never commit real values.
# Prefer [.env.dokploy.example](.env.dokploy.example) when using docker-compose.dokploy.yml.

DATABASE_URL=postgres://relay:CHANGE_ME@postgres:5432/payment_relay
REDIS_URL=redis://redis:6379
PORT=8080

# Public URL used in invoice QR / pay links (must be HTTPS in prod)
INVOICE_PAY_BASE_URL=https://payments.tekreminnovations.com

# PawaPay LIVE (not sandbox)
PAWAPAY_API_TOKEN=
PAWAPAY_BASE_URL=https://api.pawapay.io
FALLBACK_GATEWAY=pawapay

# Long random string (openssl rand -hex 32)
WEBHOOK_SIGNING_SECRET=

# Platform backoffice /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

WALLET_SEED_DEFAULTS_PATH=config/wallet_seed_defaults.json
PAY_PAGE_RATE_LIMIT=10
RUST_LOG=payment_relay=info,tower_http=info

# Do NOT set ALLOW_INSECURE_WEBHOOKS in production
