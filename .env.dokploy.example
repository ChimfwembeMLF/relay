# Paste into Dokploy → Compose → Environment

POSTGRES_USER=relay
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=payment_relay

# Hostnames are compose service names (NOT Dokploy DB app names)
DATABASE_URL=postgres://relay:CHANGE_ME_STRONG_PASSWORD@postgres:5432/payment_relay
REDIS_URL=redis://redis:6379

INVOICE_PAY_BASE_URL=https://payments.tekreminnovations.com
PORT=8080

PAWAPAY_API_TOKEN=
PAWAPAY_BASE_URL=https://api.pawapay.io
FALLBACK_GATEWAY=pawapay

WEBHOOK_SIGNING_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

WALLET_SEED_DEFAULTS_PATH=config/wallet_seed_defaults.json
PAY_PAGE_RATE_LIMIT=10
RUST_LOG=payment_relay=info,tower_http=info
