# Dokploy → Compose → Environment
# No POSTGRES_PASSWORD — use your managed DB URLs.

DATABASE_URL=postgres://postgres:PASSWORD@YOUR-PG-HOST:5432/YOUR_DB
REDIS_URL=redis://default:PASSWORD@YOUR-REDIS-HOST:6379

INVOICE_PAY_BASE_URL=https://payments.tekreminnovations.com
PORT=8080

PAWAPAY_API_TOKEN=
