# Paste into Dokploy → Compose → Environment.
# Prefer postgres:// (sqlx). postgresql:// also usually works.

# —— Dokploy-managed Postgres + Redis (internal hostnames) ——
DATABASE_URL=postgres://USER:PASSWORD@YOUR-PG-HOST:5432/YOUR_DB
REDIS_URL=redis://default:PASSWORD@YOUR-REDIS-HOST:6379

# —— Public site (must match Dokploy domain, HTTPS, no trailing slash) ——
INVOICE_PAY_BASE_URL=https://payments.tekreminnovations.com
PORT=8080

